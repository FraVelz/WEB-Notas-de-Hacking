---
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import Sidebar from "@/components/layout/Sidebar.astro";
import iconoLogo from "@/images/logos/icono.svg";

import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  showFooter?: boolean;
}

const {
  title = "Notas de Hacking",
  description = "Notas de hacking, guía para aprender o repasar al empezar en el hacking.",
  showFooter = false,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={iconoLogo.src} />

    <!-- SEO Básico -->
    <meta http-equiv="Content-Language" content="es" />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="ciberseguridad, hacking ético, pentesting, Linux, Python, redes, OSINT, anonimato"
    />
    <meta name="author" content="Fravelz" />
    <meta name="robots" content="index, follow" />
    <link
      rel="canonical"
      href="https://fravelz.github.io/WEB-Notas-de-Hacking/"
    />

    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta
      property="og:url"
      content="https://fravelz.github.io/WEB-Notas-de-Hacking/"
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta
      property="og:image"
      content="https://github.com/FraVelz/WEB-Notas-de-Hacking/blob/main/screenshot.png?raw=true"
    />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:url"
      content="https://fravelz.github.io/WEB-Notas-de-Hacking/"
    />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta
      name="twitter:image"
      content="https://github.com/FraVelz/WEB-Notas-de-Hacking/blob/main/screenshot.png?raw=true"
    />

    <title>{title} - Notas de Hacking</title>

    <script>
      // Calcular altura del header y establecerla como variable CSS
      document.addEventListener("DOMContentLoaded", () => {
        const header = document.getElementById("main-header");
        if (header) {
          const headerHeight = header.offsetHeight;
          document.documentElement.style.setProperty(
            "--header-height",
            `${headerHeight}px`,
          );
        }
      });
    </script>
  </head>

  <body
    class="bg-gray-950 text-gray-200 h-screen overflow-hidden grid grid-cols-[auto_auto] grid-rows-[auto_auto]"
  >
    <Header
      className=`h-fit flex flex-wrap items-center gap-4 p-4
      bg-gray-900
      text-gray-200
      border-b-2 border-gray-700
      shadow-lg shadow-black/20
      
      col-span-2`
    />

    <Sidebar
      className=`
    hidden lg:flex flex-col
    w-64 min-w-[16rem]
    bg-gray-900 border-r border-gray-700
    overflow-y-auto
    transition-all duration-300
    z-40
    `
    />

    <div class="overflow-y-scroll flex flex-col">
      <main class="h-full w-full">
        <slot />
      </main>

      {
        showFooter && (
          <Footer
            className={`
            bg-gray-900 text-gray-400
            border-t-2 border-gray-700
            flex flex-col align-middle
            p-5 gap-3
          `}
          />
        )
      }
    </div>
  </body>
</html>
